{
  "name": "vscode-tsundere",
  "displayName": "Tsundere",
  "description": "VS Code support for Tsundere .yuri files.",
  "version": "0.1.0",
  "publisher": "tsundere",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsundere-lang/tsundere"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": ["Programming Languages"],
  "icon": "assets/tsundere-logo.png",
  "activationEvents": [
    "onLanguage:yuri",
    "onCommand:tsundere.createProject"
  ],
  "contributes": {
    "languages": [
      {
        "id": "yuri",
        "aliases": ["Tsundere", "yuri"],
        "extensions": [".yuri"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/tsundere-logo.png",
          "dark": "./assets/tsundere-logo.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "yuri",
        "scopeName": "source.yuri",
        "path": "./syntaxes/yuri.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "yuri",
        "path": "./snippets/yuri-discord.code-snippets"
      }
    ],
    "commands": [
      { "command": "tsundere.createProject", "title": "Tsundere: Create Project" },
      { "command": "tsundere.runDevServer", "title": "Tsundere: Run Dev Server" },
      { "command": "tsundere.buildProject", "title": "Tsundere: Build Project" },
      { "command": "tsundere.syncCommands", "title": "Tsundere: Sync Commands" },
      { "command": "tsundere.generateTypes", "title": "Tsundere: Generate Types" },
      { "command": "tsundere.openDocs", "title": "Tsundere: Open Docs" },
      { "command": "tsundere.formatFile", "title": "Tsundere: Format File" },
      { "command": "tsundere.restartLanguageServer", "title": "Tsundere: Restart Language Server" }
    ],
    "configuration": {
      "title": "Tsundere",
      "properties": {
        "tsundere.server.path": {
          "type": "string",
          "default": "yurils",
          "description": "Path to the YuriLS language server."
        },
        "tsundere.discord.autocomplete": {
          "type": "boolean",
          "default": true,
          "description": "Enable Discord-aware completions for @tsundere/discord imports."
        }
      }
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "prepare-assets": "node scripts/prepare-assets.mjs",
    "build": "npm run prepare-assets && tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "check": "npm run build",
    "package": "npm run build && vsce package --no-dependencies",
    "publish": "npm run build && vsce publish",
    "clean": "node scripts/clean.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
