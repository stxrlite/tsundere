{
  "name": "tsundere-installer",
  "version": "0.1.1",
  "description": "Electron-based Windows installer for Tsundere.",
  "author": "TsundereLang",
  "private": true,
  "type": "commonjs",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win nsis portable",
    "build:portable": "electron-builder --win portable",
    "build:nsis": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.tsundere.installer",
    "productName": "Tsundere Setup",
    "copyright": "Copyright © TsundereLang",
    "asar": true,
    "directories": {
      "output": "out"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../assets",
        "to": "assets"
      },
      {
        "from": "../../docs/local",
        "to": "docs/local"
      },
      {
        "from": "../windows/TsundereUninstall.ps1",
        "to": "scripts/TsundereUninstall.ps1"
      },
      {
        "from": "../../release",
        "to": "payload",
        "filter": [
          "tsundere-cli*.tgz",
          "tsundere-discord*.tgz",
          "vscode-tsundere*.vsix"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "../../assets/vscode-tsundere-logo.png",
      "artifactName": "Tsundere-Setup-${version}-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "Tsundere Setup"
    }
  }
}
